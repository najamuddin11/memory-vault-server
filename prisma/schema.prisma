// Prisma schema for the portfolio backend.
// Run `npx prisma migrate dev --name init` after setting DATABASE_URL to
// create the database tables from this file.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------
// Portfolio (projects) + their image gallery
// ---------------------------------------------------------------------

model Portfolio {
  id               Int     @id @default(autoincrement())
  slug             String  @unique
  featured         Boolean @default(false)
  title            String
  companyBuiltWith String?
  desc             String
  projectColor     String?
  projectText      String?
  outcome          String?
  link             String?
  moreInfoLink     String?

  // Filenames / relative paths only, e.g. "portfolio/cardo/cover.png".
  // The GraphQL resolver prefixes these with IMAGE_BASE_URL before they
  // reach the frontend - see src/utils/imageUrl.ts.
  projectLogo String?
  image       String

  status String
  skills String[]
  order  Int      @default(0)

  carousel CarouselItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("portfolios")
}

model Intro {
  id        Int     @id @default(autoincrement())
  img       String
  firstName String?
  lastName  String?
  summary   String?
  resume    String?

  @@map("intro")
}

model CarouselItem {
  id       Int     @id @default(autoincrement())
  img      String
  desc     String?
  title    String?
  gridArea String?
  order    Int     @default(0)

  portfolioId Int
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)

  @@map("carousel_items")
}

// ---------------------------------------------------------------------
// Everything else on the home page
// ---------------------------------------------------------------------

model Service {
  id        Int    @id @default(autoincrement())
  iconLight String
  iconDark  String
  title     String
  details   String
  order     Int    @default(0)

  @@map("services")
}

model Education {
  id       Int    @id @default(autoincrement())
  city     String
  duration String
  academy  String
  degree   String
  order    Int    @default(0)

  @@map("education")
}

model WorkExperience {
  id                 Int      @id @default(autoincrement())
  duration           String
  designation        String
  company            String
  location           String?
  icon               String?
  companyDescription String
  // Array of { title, desc } objects - kept as JSON since it's a small,
  // view-specific shape rather than something queried/filtered on.
  whatIdid           Json
  skillsUsed         String[]
  achievement        String?
  companySite        String?
  order              Int      @default(0)

  @@map("work_experience")
}

model Skill {
  id       Int     @id @default(autoincrement())
  title    String
  level    String?
  progress Int?
  order    Int     @default(0)

  @@map("skills")
}

model Testimonial {
  id          Int    @id @default(autoincrement())
  profile     String
  name        String
  designation String
  description String
  order       Int    @default(0)

  @@map("testimonials")
}

model ContactInfo {
  id        Int      @id @default(autoincrement())
  text      String[]
  iconLight String
  iconDark  String
  link      String
  order     Int      @default(0)

  @@map("contact_info")
}

// Messages submitted through the contact form.
model ContactMessage {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())

  @@map("contact_messages")
}
