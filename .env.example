# Copy to .env for local dev. On Render, set these in the dashboard instead
# (never commit a real .env file).

# Postgres connection string.
# Local docker-compose:  postgresql://portfolio:portfolio@localhost:5432/portfolio
# Neon (production):     get this from your Neon project dashboard
DATABASE_URL=

PORT=4000
NODE_ENV=development

# Comma-separated list of frontend origins allowed to call this API
ALLOWED_ORIGINS=http://localhost:5174

# Any long random string, used to sign CSRF tokens
CSRF_SECRET=

# SMTP settings for the contact form (e.g. from Gmail, Resend, etc.)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
